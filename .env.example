# Upstash Redis (REST API) — przechowuje edytowalne dane strony (link do rezerwacji, kontakt, notatki w przewodniku)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Panel administracyjny
ADMIN_PASSWORD=
# Losowy, długi ciąg znaków używany do podpisywania sesji (np. wygenerowany przez `openssl rand -hex 32`)
ADMIN_SESSION_SECRET=
