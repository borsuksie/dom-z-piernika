---
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Locale, Dictionary } from '../i18n';

interface Props {
  locale: Locale;
  t: Dictionary;
  path: string;
  /** Use on top of a full-bleed photo hero: transparent background, white text. */
  transparent?: boolean;
}

const { locale, t, path, transparent = false } = Astro.props;
---

<header class="site-header" data-transparent={transparent}>
  <a class="brand" href={`/${locale}/`}>🏠 {t.hero.title}</a>
  <nav>
    <a href={`/${locale}/`}>{t.nav.home}</a>
    <a href={`/${locale}/guide/`}>{t.nav.guide}</a>
    <LanguageSwitcher locale={locale} path={path} label={t.nav.selectLanguage} />
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    max-width: 1080px;
    margin: 0 auto;
  }

  .brand {
    font-weight: 800;
    font-size: 1.25rem;
    text-decoration: none;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  nav a:hover {
    color: var(--accent);
  }

  .site-header[data-transparent='true'] {
    max-width: none;
    border-bottom-color: rgba(255, 255, 255, 0.2);
  }

  .site-header[data-transparent='true'] .brand,
  .site-header[data-transparent='true'] nav a {
    color: #fff;
  }

  .site-header[data-transparent='true'] nav a:hover {
    color: var(--accent);
  }
</style>
