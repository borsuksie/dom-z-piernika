---
import GuideCategoryPage from '../../../views/GuideCategoryPage.astro';
import { isCategorySlug } from '../../../data/guide/categories';

const { category } = Astro.params;

if (!category || !isCategorySlug(category)) {
  return Astro.redirect('/de/guide/', 302);
}
---

<GuideCategoryPage locale="de" category={category} />
