---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import PoiCard from '../components/PoiCard.astro';
import { getDictionary, type Locale } from '../i18n';
import { getGuideDictionary } from '../i18n/guide';
import { houseFacts } from '../data/house';
import { categorySlugs, categoryIcons, type CategorySlug } from '../data/guide/categories';
import { poisByCategory } from '../data/guide/pois';
import { getAllPoiNotices } from '../lib/site';

interface Props {
  locale: Locale;
  category: CategorySlug;
}

const { locale, category } = Astro.props;
const t = getDictionary(locale);
const guideCopy = getGuideDictionary(locale);
const notices = await getAllPoiNotices();

const items = poisByCategory(category);
const categoryCopy = t.categories[category];

const site = Astro.site ?? new URL('https://domekzpiernika.com');
const pageUrl = new URL(`/${locale}/guide/${category}/`, site).toString();
const homeUrl = new URL(`/${locale}/`, site).toString();
const guideUrl = new URL(`/${locale}/guide/`, site).toString();

const pageTitle = `${categoryCopy.name} — ${t.guideIndex.title}`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: categoryCopy.name,
    url: pageUrl,
    inLanguage: locale,
    itemListElement: items.map((poi, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'TouristAttraction',
        name: poi.name,
        description: guideCopy[poi.id]?.description,
        url: poi.mapsUrl,
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t.nav.home, item: homeUrl },
      { '@type': 'ListItem', position: 2, name: t.nav.guide, item: guideUrl },
      { '@type': 'ListItem', position: 3, name: categoryCopy.name, item: pageUrl },
    ],
  },
];
---

<BaseLayout locale={locale} title={pageTitle} description={categoryCopy.description} path={`guide/${category}/`} jsonLd={jsonLd}>
  <SiteHeader locale={locale} t={t} path={`guide/${category}/`} />

  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href={`/${locale}/`}>{t.nav.home}</a>
      <span aria-hidden="true">/</span>
      <a href={`/${locale}/guide/`}>{t.nav.guide}</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{categoryCopy.name}</span>
    </nav>

    <section class="intro">
      <h1>{categoryIcons[category]} {categoryCopy.name}</h1>
      <p>{categoryCopy.description}</p>
    </section>

    <nav class="category-pills">
      {categorySlugs.map((slug) => (
        <a href={`/${locale}/guide/${slug}/`} class="pill" data-active={slug === category}>
          {categoryIcons[slug]} {t.categories[slug].name}
        </a>
      ))}
    </nav>

    <section class="poi-grid">
      {items.map((poi) => (
        <PoiCard poi={poi} copy={guideCopy[poi.id]} notice={notices[poi.id] ?? ''} t={t.guideCategory} />
      ))}
    </section>

    <p class="back">
      <a href={`/${locale}/guide/`}>{t.guideCategory.backToGuide}</a>
    </p>
  </main>

  <footer class="site-footer">
    <p>{t.footer.disclaimer}</p>
    <p>© {new Date().getFullYear()} {houseFacts.name}. {t.footer.rights}</p>
  </footer>
</BaseLayout>

<style>
  main {
    max-width: 1080px;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 3rem;
  }

  .breadcrumbs {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .breadcrumbs a {
    color: var(--muted);
  }

  .intro {
    margin-bottom: 1.5rem;
  }

  .intro h1 {
    font-size: clamp(1.7rem, 4.5vw, 2.3rem);
    margin-bottom: 0.5rem;
  }

  .intro p {
    color: var(--muted);
    max-width: 640px;
  }

  .category-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .pill {
    text-decoration: none;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 0.85rem;
    font-size: 0.82rem;
    white-space: nowrap;
  }

  .pill[data-active='true'] {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    font-weight: 600;
  }

  .poi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .back {
    margin-top: 1rem;
  }

  .back a {
    font-weight: 600;
  }

  .site-footer {
    max-width: 1080px;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 2.5rem;
    color: var(--muted);
    font-size: 0.8rem;
    border-top: 1px solid var(--border);
  }
</style>
